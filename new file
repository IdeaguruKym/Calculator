<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Insurance Premium Calculator</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Crimson+Text:ital@0;1&family=DM+Sans:wght@300;400;500;600&family=DM+Serif+Display:ital@0;1&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --navy:        #0b0f1a;
      --navy-2:      #111827;
      --navy-3:      #1a2235;
      --navy-4:      #1e2a42;
      --gold:        #c9a84c;
      --gold-light:  #e8c96e;
      --gold-dim:    rgba(201,168,76,0.15);
      --gold-border: rgba(201,168,76,0.3);
      --text:        #e8e8e0;
      --text-muted:  #8a8f9e;
      --text-dim:    #5a6072;
      --green:       #4ade80;
      --red:         #f87171;
      --radius:      12px;
    }

    body {
      background: var(--navy);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'DM Sans', sans-serif;
      padding: 2rem;
    }

    /* ── Card ── */
    .card {
      background: var(--navy-2);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 20px;
      width: 100%;
      max-width: 580px;
      overflow: hidden;
      box-shadow: 0 40px 80px rgba(0,0,0,0.6), 0 0 0 1px rgba(201,168,76,0.08);
    }
    .card-header {
      background: linear-gradient(135deg, #111827 0%, #1a2235 100%);
      padding: 2rem 2rem 1.75rem;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      position: relative; overflow: hidden;
    }
    .card-header::before {
      content: ''; position: absolute; top: -40px; right: -40px;
      width: 180px; height: 180px;
      background: radial-gradient(circle, rgba(201,168,76,0.12) 0%, transparent 70%);
      border-radius: 50%; pointer-events: none;
    }
    .header-label { font-family:'JetBrains Mono',monospace; font-size:0.65rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--gold); margin-bottom:0.5rem; }
    .header-title { font-family:'DM Serif Display',serif; font-size:1.75rem; color:var(--text); line-height:1.2; font-style:italic; }
    .header-title span { color:var(--gold-light); font-style:normal; }
    .header-sub { font-size:0.8rem; color:var(--text-muted); margin-top:0.4rem; font-weight:300; }

    .card-body { padding:1.75rem 2rem; display:flex; flex-direction:column; gap:1.25rem; }

    .field { display:flex; flex-direction:column; gap:0.5rem; }
    .field-label { font-size:0.7rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--text-muted); font-weight:500; }

    .input-wrap { position:relative; display:flex; align-items:center; }
    .input-prefix { position:absolute; left:14px; font-family:'JetBrains Mono',monospace; font-size:0.85rem; color:var(--gold); pointer-events:none; z-index:1; }
    .input-field {
      width:100%; background:var(--navy-3); border:1px solid rgba(255,255,255,0.08);
      border-radius:var(--radius); padding:0.85rem 1rem 0.85rem 2rem;
      color:var(--text); font-family:'JetBrains Mono',monospace; font-size:1rem; font-weight:500;
      outline:none; transition:border-color 0.2s,box-shadow 0.2s,background 0.2s; -webkit-appearance:none;
    }
    .input-field:focus { border-color:var(--gold-border); background:var(--navy-4); box-shadow:0 0 0 3px rgba(201,168,76,0.08),inset 0 1px 2px rgba(0,0,0,0.3); }
    .input-field::placeholder { color:var(--text-dim); }

    .option-group { display:grid; grid-template-columns:1fr 1fr 1fr; gap:0.5rem; }
    .option-pill {
      background:var(--navy-3); border:1px solid rgba(255,255,255,0.07); border-radius:var(--radius);
      padding:0.65rem 0.5rem; cursor:pointer; transition:all 0.18s ease; text-align:center;
      display:flex; flex-direction:column; gap:0.2rem; align-items:center; user-select:none;
    }
    .option-pill:hover { border-color:var(--gold-border); background:var(--navy-4); }
    .option-pill.active { background:var(--gold-dim); border-color:var(--gold); box-shadow:0 0 16px rgba(201,168,76,0.15); }
    .option-pill-name { font-size:0.75rem; font-weight:600; letter-spacing:0.06em; text-transform:uppercase; color:var(--text-muted); transition:color 0.18s; }
    .option-pill.active .option-pill-name { color:var(--gold-light); }
    .option-pill-desc { font-size:0.62rem; color:var(--text-dim); line-height:1.3; }
    .option-pill.active .option-pill-desc { color:var(--text-muted); }

    .divider { height:1px; background:linear-gradient(to right,transparent,rgba(255,255,255,0.06),transparent); }

    .result-box { background:var(--navy-3); border:1px solid rgba(255,255,255,0.07); border-radius:var(--radius); overflow:hidden; }
    .result-row { display:flex; justify-content:space-between; align-items:center; padding:0.7rem 1rem; border-bottom:1px solid rgba(255,255,255,0.04); }
    .result-row:last-child { border-bottom:none; }
    .result-row-label { font-size:0.78rem; color:var(--text-muted); }
    .result-row-value { font-family:'JetBrains Mono',monospace; font-size:0.82rem; color:var(--text); font-weight:500; }
    .result-total { background:linear-gradient(135deg,rgba(201,168,76,0.12),rgba(201,168,76,0.06)); border-top:1px solid var(--gold-border) !important; }
    .result-total .result-row-label { font-weight:600; color:var(--text); font-size:0.82rem; letter-spacing:0.04em; }
    .result-total .result-row-value { font-size:1.15rem; color:var(--gold-light); }

    @keyframes pulse-gold { 0%{transform:scale(1.04);opacity:.7} 100%{transform:scale(1);opacity:1} }
    .result-animate { animation:pulse-gold 0.35s ease-out; }

    .shipping-badge { display:inline-flex; align-items:center; gap:0.3rem; font-size:0.65rem; padding:0.2rem 0.45rem; border-radius:4px; background:rgba(74,222,128,0.1); color:var(--green); border:1px solid rgba(74,222,128,0.4); }

    .referral-alert { background:rgba(248,113,113,0.08); border:1px solid rgba(248,113,113,0.3); border-radius:var(--radius); padding:1rem 1.25rem; display:flex; gap:0.75rem; align-items:flex-start; }
    .referral-icon { font-size:1.1rem; flex-shrink:0; margin-top:1px; }
    .referral-title { font-size:0.8rem; font-weight:600; color:var(--red); letter-spacing:0.05em; text-transform:uppercase; margin-bottom:0.25rem; }
    .referral-text { font-size:0.75rem; color:var(--text-muted); line-height:1.5; }

    .empty-state { text-align:center; padding:1.5rem 1rem; color:var(--text-dim); font-size:0.8rem; font-style:italic; }

    /* ── Accept Button ── */
    .accept-btn {
      width:100%; padding:0.95rem;
      background:linear-gradient(135deg,var(--gold) 0%,#a8852e 100%);
      color:#0b0f1a; font-family:'DM Sans',sans-serif; font-size:0.85rem; font-weight:700;
      letter-spacing:0.1em; text-transform:uppercase; border:none; border-radius:var(--radius);
      cursor:pointer; transition:all 0.2s ease; box-shadow:0 4px 20px rgba(201,168,76,0.35);
      display:flex; align-items:center; justify-content:center; gap:0.5rem;
    }
    .accept-btn:hover { transform:translateY(-1px); box-shadow:0 8px 28px rgba(201,168,76,0.45); background:linear-gradient(135deg,#e8c96e 0%,#c9a84c 100%); }
    .accept-btn:active { transform:translateY(0); }
    .accept-btn.hidden { display:none; }

    /* ── Rate Table ── */
    .table-toggle { display:flex; align-items:center; justify-content:space-between; cursor:pointer; padding:0.6rem 0; user-select:none; }
    .table-toggle-label { font-size:0.7rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--text-muted); font-weight:500; transition:color 0.15s; }
    .table-toggle:hover .table-toggle-label { color:var(--gold); }
    .table-toggle-icon { color:var(--text-dim); font-size:0.7rem; transition:transform 0.25s ease,color 0.15s; }
    .table-toggle.open .table-toggle-icon { transform:rotate(180deg); color:var(--gold); }
    .rate-table-wrap { overflow:hidden; max-height:0; transition:max-height 0.35s ease; }
    .rate-table-wrap.open { max-height:700px; }
    .rate-table { width:100%; border-collapse:collapse; border-radius:var(--radius); overflow:hidden; margin-top:0.5rem; }
    .rate-table th { background:var(--navy-4); padding:0.55rem 0.75rem; text-align:left; font-family:'JetBrains Mono',monospace; font-size:0.62rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--gold); }
    .rate-table th:not(:first-child) { text-align:right; }
    .rate-table td { padding:0.5rem 0.75rem; color:var(--text-muted); border-bottom:1px solid rgba(255,255,255,0.03); font-family:'JetBrains Mono',monospace; font-size:0.7rem; }
    .rate-table td:not(:first-child) { text-align:right; }
    .rate-table tr:last-child td { border-bottom:none; }
    .rate-table tr.active-row td { background:var(--gold-dim); color:var(--text); font-weight:500; }
    .rate-table tr.active-row td:first-child { border-left:2px solid var(--gold); color:var(--gold-light); }
    .rate-table tr:not(.active-row):hover td { background:rgba(255,255,255,0.02); }

    .card-footer { border-top:1px solid rgba(255,255,255,0.04); padding:0.9rem 2rem; display:flex; justify-content:space-between; align-items:center; }
    .footer-note { font-size:0.67rem; color:var(--text-dim); }
    .footer-tax { font-family:'JetBrains Mono',monospace; font-size:0.65rem; color:var(--text-dim); }

    /* ══════════════════════════════════
       MODAL
    ══════════════════════════════════ */
    .modal-overlay {
      position:fixed; inset:0; background:rgba(0,0,0,0.85); backdrop-filter:blur(6px);
      z-index:999; display:flex; align-items:center; justify-content:center; padding:1.5rem;
      opacity:0; pointer-events:none; transition:opacity 0.3s ease;
    }
    .modal-overlay.visible { opacity:1; pointer-events:all; }

    .cert-wrap {
      width:100%; max-width:740px; max-height:90vh; overflow-y:auto;
      border-radius:4px;
      transform:scale(0.92) translateY(20px);
      transition:transform 0.35s cubic-bezier(0.34,1.3,0.64,1);
    }
    .modal-overlay.visible .cert-wrap { transform:scale(1) translateY(0); }

    /* ══════════════════════════════════
       CERTIFICATE
    ══════════════════════════════════ */
    .certificate {
      background:#faf7f0; position:relative;
      padding:3.25rem 3.75rem 2.5rem;
      font-family:'Crimson Text',serif; color:#1a1410; overflow:hidden;
    }

    /* Double border frame */
    .certificate::before {
      content:''; position:absolute; inset:10px;
      border:2px solid currentColor; pointer-events:none; z-index:0; opacity:0.2;
    }
    .certificate::after {
      content:''; position:absolute; inset:17px;
      border:1px solid currentColor; pointer-events:none; z-index:0; opacity:0.1;
    }

    /* Corner ornaments */
    .cert-corner { position:absolute; width:56px; height:56px; opacity:0.4; }
    .cert-corner.tl { top:6px; left:6px; }
    .cert-corner.tr { top:6px; right:6px; transform:scaleX(-1); }
    .cert-corner.bl { bottom:6px; left:6px; transform:scaleY(-1); }
    .cert-corner.br { bottom:6px; right:6px; transform:scale(-1,-1); }

    /* Per-option accent colours */
    .cert-with    { --acc:#7a5c1e; --acc2:#c9a84c; --seal:#c9a84c; --seal-r:#7a5c1e; --badge:#fdf3dc; }
    .cert-without { --acc:#1e3d5c; --acc2:#4a7ea8; --seal:#6aafd4; --seal-r:#1e3d5c; --badge:#e5f0f8; }
    .cert-tenta   { --acc:#4a3200; --acc2:#c07a00; --seal:#e09820; --seal-r:#4a3200; --badge:#fff4d6; }

    .cert-header { text-align:center; margin-bottom:1.5rem; position:relative; z-index:1; }
    .cert-issuer { font-family:'Cinzel',serif; font-size:0.62rem; letter-spacing:0.22em; text-transform:uppercase; color:var(--acc); margin-bottom:0.5rem; opacity:0.75; }
    .cert-title-main { font-family:'Cinzel',serif; font-size:1.8rem; font-weight:700; letter-spacing:0.05em; color:var(--acc); line-height:1.15; margin-bottom:0.3rem; }
    .cert-title-sub { font-family:'Cinzel',serif; font-size:0.8rem; font-weight:400; letter-spacing:0.16em; color:var(--acc2); }

    .cert-ornament { display:flex; align-items:center; gap:0.6rem; margin:1rem 0; position:relative; z-index:1; }
    .cert-ornament::before,.cert-ornament::after { content:''; flex:1; height:1px; background:var(--acc); opacity:0.25; }
    .cert-diamond { width:7px; height:7px; background:var(--acc2); transform:rotate(45deg); flex-shrink:0; opacity:0.85; }

    .cert-intro { text-align:center; font-size:0.97rem; font-style:italic; color:#3a3028; margin-bottom:1.25rem; line-height:1.65; position:relative; z-index:1; }

    .cert-type-badge {
      display:block; margin:0 auto 1.75rem; width:fit-content;
      background:var(--badge); border:1.5px solid var(--acc2); border-radius:3px;
      padding:0.45rem 1.6rem;
      font-family:'Cinzel',serif; font-size:0.82rem; font-weight:600; letter-spacing:0.1em;
      color:var(--acc); text-align:center; position:relative; z-index:1;
    }

    .cert-grid { display:grid; grid-template-columns:1fr 1fr; margin-bottom:1.5rem; position:relative; z-index:1; border:1px solid rgba(122,92,30,0.14); border-radius:3px; overflow:hidden; }
    .cert-field { padding:0.65rem 1rem; border-bottom:1px solid rgba(122,92,30,0.1); background:#fff; }
    .cert-field:nth-child(odd) { border-right:1px solid rgba(122,92,30,0.1); }
    .cert-field:nth-last-child(-n+2) { border-bottom:none; }
    .cert-field-label { font-family:'Cinzel',serif; font-size:0.55rem; letter-spacing:0.15em; text-transform:uppercase; color:var(--acc2); margin-bottom:0.25rem; }
    .cert-field-value { font-size:0.95rem; font-weight:600; color:var(--acc); line-height:1.2; }

    .cert-premium-row {
      background:var(--badge); border:1.5px solid var(--acc2); border-radius:3px;
      padding:0.85rem 1.25rem; display:flex; justify-content:space-between; align-items:center;
      margin-bottom:1.75rem; position:relative; z-index:1;
    }
    .cert-premium-label { font-family:'Cinzel',serif; font-size:0.62rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--acc); }
    .cert-premium-desc { font-size:0.72rem; color:#7a6a58; font-style:italic; margin-top:0.2rem; max-width:320px; line-height:1.4; }
    .cert-premium-value { font-family:'Cinzel',serif; font-size:1.55rem; font-weight:700; color:var(--acc); white-space:nowrap; }

    .cert-seal-row { display:flex; justify-content:space-between; align-items:flex-end; position:relative; z-index:1; margin-top:0.25rem; }
    .cert-signatures { display:flex; gap:2.5rem; }
    .cert-sig { display:flex; flex-direction:column; gap:0.15rem; }
    .cert-sig-line { width:130px; height:1px; background:var(--acc); opacity:0.35; margin-bottom:0.3rem; }
    .cert-sig-name { font-family:'Cinzel',serif; font-size:0.58rem; letter-spacing:0.1em; color:var(--acc); }
    .cert-sig-title { font-size:0.65rem; color:#7a6a58; font-style:italic; }

    .cert-seal {
      width:88px; height:88px; border-radius:50%;
      border:3px solid var(--seal-r);
      background:radial-gradient(circle at 38% 32%,rgba(255,255,255,0.4),transparent 55%), var(--seal);
      display:flex; flex-direction:column; align-items:center; justify-content:center;
      box-shadow:inset 0 2px 8px rgba(0,0,0,0.15),0 4px 18px rgba(0,0,0,0.22);
      flex-shrink:0; outline:2px dashed var(--seal-r); outline-offset:-8px;
    }
    .cert-seal-star { font-size:1.05rem; color:#fff; line-height:1; }
    .cert-seal-text { font-family:'Cinzel',serif; font-size:0.37rem; letter-spacing:0.07em; color:#fff; text-transform:uppercase; font-weight:700; margin-top:3px; line-height:1.4; text-align:center; }

    /* Provisional watermark */
    .cert-watermark {
      position:absolute; top:50%; left:50%; transform:translate(-50%,-50%) rotate(-35deg);
      font-family:'Cinzel',serif; font-size:4.8rem; font-weight:700; letter-spacing:0.1em;
      color:rgba(193,127,0,0.065); pointer-events:none; white-space:nowrap; z-index:0; user-select:none;
    }

    /* Bottom policy bar */
    .cert-policy-bar {
      background:var(--acc); color:#faf7f0;
      padding:0.5rem 1.25rem; margin:1.5rem -3.75rem -2.5rem;
      display:flex; justify-content:space-between; align-items:center;
      position:relative; z-index:1;
    }
    .cert-policy-num { font-family:'JetBrains Mono',monospace; font-size:0.68rem; letter-spacing:0.12em; }
    .cert-policy-date { font-size:0.68rem; font-style:italic; opacity:0.78; font-family:'Crimson Text',serif; }

    /* Modal action bar */
    .cert-actions { background:#12100d; padding:0.9rem 1.5rem; display:flex; gap:0.75rem; justify-content:flex-end; align-items:center; }
    .btn-close {
      background:transparent; border:1px solid rgba(255,255,255,0.14); color:var(--text-muted);
      padding:0.5rem 1.1rem; border-radius:8px; cursor:pointer; font-size:0.78rem;
      font-family:'DM Sans',sans-serif; letter-spacing:0.04em; transition:all 0.15s;
    }
    .btn-close:hover { border-color:rgba(255,255,255,0.3); color:var(--text); }
    .btn-print {
      background:linear-gradient(135deg,var(--gold) 0%,#a8852e 100%); border:none; color:#0b0f1a;
      padding:0.5rem 1.4rem; border-radius:8px; cursor:pointer; font-size:0.78rem;
      font-family:'DM Sans',sans-serif; font-weight:700; letter-spacing:0.08em; text-transform:uppercase;
      transition:all 0.15s; box-shadow:0 2px 12px rgba(201,168,76,0.3);
    }
    .btn-print:hover { transform:translateY(-1px); box-shadow:0 6px 20px rgba(201,168,76,0.4); }

    @media print {
      body { background:white; padding:0; min-height:auto; }
      .card { display:none; }
      .modal-overlay { position:static; background:none; backdrop-filter:none; padding:0; opacity:1; pointer-events:all; }
      .cert-wrap { max-height:none; overflow:visible; transform:none !important; max-width:none; }
      .cert-actions { display:none; }
      .certificate { padding:2.5rem 3rem; }
    }
  </style>
</head>
<body>

<!-- ════════════ QUOTE CARD ════════════ -->
<div class="card">
  <div class="card-header">
    <div class="header-label">Commercial Insurance</div>
    <div class="header-title">Instant <span>Premium</span> Calculator</div>
    <div class="header-sub">Enter annual revenue to generate a real-time quote</div>
  </div>

  <div class="card-body">
    <div class="field">
      <div class="field-label">Annual Revenue (CAD)</div>
      <div class="input-wrap">
        <span class="input-prefix">$</span>
        <input id="revenueInput" class="input-field" type="text" inputmode="numeric" placeholder="0" />
      </div>
    </div>

    <div class="field">
      <div class="field-label">Coverage Type</div>
      <div class="option-group">
        <div class="option-pill active" data-option="WITH">
          <div class="option-pill-name">With</div>
          <div class="option-pill-desc">Comprehensive coverage</div>
        </div>
        <div class="option-pill" data-option="WITHOUT">
          <div class="option-pill-name">Without</div>
          <div class="option-pill-desc">Core protection only</div>
        </div>
        <div class="option-pill" data-option="TENTA">
          <div class="option-pill-name">Tentative</div>
          <div class="option-pill-desc">Subject to review</div>
        </div>
      </div>
    </div>

    <div class="divider"></div>

    <div id="resultArea">
      <div class="empty-state">Enter a revenue figure above to generate your quote</div>
    </div>

    <button class="accept-btn hidden" id="acceptBtn">
      ✔&nbsp; Accept Quote &amp; Generate Certificate
    </button>

    <div class="divider"></div>

    <div>
      <div class="table-toggle" id="tableToggle">
        <span class="table-toggle-label">Rate Schedule</span>
        <span class="table-toggle-icon">▼</span>
      </div>
      <div class="rate-table-wrap" id="rateTableWrap">
        <table class="rate-table">
          <thead>
            <tr><th>Revenue Band</th><th>With</th><th>Without</th><th>Tentative</th></tr>
          </thead>
          <tbody id="rateTableBody"></tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="card-footer">
    <span class="footer-note">Rates effective 2025 · Subject to change</span>
    <span class="footer-tax">HST 13% incl.</span>
  </div>
</div>

<!-- ════════════ MODAL ════════════ -->
<div class="modal-overlay" id="modal">
  <div class="cert-wrap">
    <div class="certificate" id="certificateEl"></div>
    <div class="cert-actions">
      <button class="btn-close" id="btnClose">✕ Close</button>
      <button class="btn-print" onclick="window.print()">⎙ Print / Save PDF</button>
    </div>
  </div>
</div>

<!-- Hidden SVG symbol for corner ornament -->
<svg style="display:none">
  <symbol id="corner-sym" viewBox="0 0 56 56">
    <path d="M4 4 L4 28 M4 4 L28 4" stroke="currentColor" stroke-width="1.5" fill="none"/>
    <circle cx="4" cy="4" r="2.5" fill="currentColor"/>
    <path d="M14 4 Q20 4 20 14" stroke="currentColor" stroke-width="0.8" fill="none" opacity="0.6"/>
    <path d="M4 14 Q4 20 14 20" stroke="currentColor" stroke-width="0.8" fill="none" opacity="0.6"/>
  </symbol>
</svg>

<script>
  /* ── Data ── */
  const rates = [
    { min: 0,        WITH: 227,   WITHOUT: 173,  TENTA: 295   },
    { min: 250001,   WITH: 475,   WITHOUT: 227,  TENTA: 715   },
    { min: 500001,   WITH: 718,   WITHOUT: 254,  TENTA: 1075  },
    { min: 1000001,  WITH: 1274,  WITHOUT: 378,  TENTA: 1910  },
    { min: 2000001,  WITH: 1820,  WITHOUT: 551,  TENTA: 2730  },
    { min: 3000001,  WITH: 2538,  WITHOUT: 761,  TENTA: 3805  },
    { min: 4000001,  WITH: 3261,  WITHOUT: 853,  TENTA: 4890  },
    { min: 5000001,  WITH: 3504,  WITHOUT: 1037, TENTA: 5250  },
    { min: 6000001,  WITH: 4142,  WITHOUT: 1226, TENTA: 6215  },
    { min: 7000001,  WITH: 4773,  WITHOUT: 1409, TENTA: 7160  },
    { min: 8000001,  WITH: 5411,  WITHOUT: 1469, TENTA: 8115  },
    { min: 9000001,  WITH: 5832,  WITHOUT: 1533, TENTA: 8750  },
    { min: 10000001, WITH: 6707,  WITHOUT: 1763, TENTA: 9775  },
    { min: 12500001, WITH: 8048,  WITHOUT: 2116, TENTA: 10830 },
    { min: 15000001, WITH: 9658,  WITHOUT: 2539, TENTA: 13230 },
    { min: 17500001, WITH: 11300, WITHOUT: 2970, TENTA: 15650 },
  ];

  const bandLabels = [
    "$0 – $250K","$250K – $500K","$500K – $1M","$1M – $2M",
    "$2M – $3M","$3M – $4M","$4M – $5M","$5M – $6M",
    "$6M – $7M","$7M – $8M","$8M – $9M","$9M – $10M",
    "$10M – $12.5M","$12.5M – $15M","$15M – $17.5M","$17.5M+",
  ];

  const OPTION_META = {
    WITH: {
      label:      "With Coverage",
      policyType: "Comprehensive Commercial Policy",
      certClass:  "cert-with",
      sealLines:  ["FULL", "COVERAGE"],
      desc:       "Comprehensive coverage including all standard add-ons and endorsements as specified in the policy schedule.",
    },
    WITHOUT: {
      label:      "Without Coverage",
      policyType: "Basic Commercial Policy",
      certClass:  "cert-without",
      sealLines:  ["BASIC", "POLICY"],
      desc:       "Core commercial protection covering essential business liabilities as defined in the base policy schedule.",
    },
    TENTA: {
      label:      "Tentative",
      policyType: "Provisional Policy — Pending Underwriter Review",
      certClass:  "cert-tenta",
      sealLines:  ["PROV.", "ISSUED"],
      desc:       "This provisional certificate is subject to final underwriter review and approval. Coverage is not bound until confirmed in writing.",
      watermark:  true,
    },
  };

  const TAX        = 0.13;
  const SHIP_CAP   = 5000000;
  const SHIP_FEE   = 50;
  const REFERRAL   = 20000000;

  let opt = "WITH";
  let rev = 0;

  /* ── Helpers ── */
  const cad  = v => new Intl.NumberFormat("en-CA",{style:"currency",currency:"CAD",minimumFractionDigits:2}).format(v);
  const num  = v => new Intl.NumberFormat("en-CA").format(v);
  const getPremium = (r,o) => { const b=[...rates].reverse().find(x=>r>=x.min); return b?b[o]:0; };
  const policyNo = () => {
    const L="ABCDEFGHJKLMNPQRSTUVWXYZ";
    const rnd = n => Array.from({length:n},()=>~~(Math.random()*10)).join("");
    return `${L[~~(Math.random()*L.length)]}-${rnd(4)}-${rnd(6)}`;
  };
  const fmtDate = d => d.toLocaleDateString("en-CA",{year:"numeric",month:"long",day:"numeric"});
  const todayStr  = () => fmtDate(new Date());
  const expiryStr = () => { const d=new Date(); d.setFullYear(d.getFullYear()+1); return fmtDate(d); };
  const getBand   = r => { const i=[...rates].reverse().findIndex(x=>r>=x.min); return i>=0?bandLabels[rates.length-1-i]:"—"; };

  /* ── Build rate table ── */
  const tbody = document.getElementById("rateTableBody");
  rates.forEach((r,i)=>{
    const tr=document.createElement("tr");
    tr.dataset.index=i;
    tr.innerHTML=`<td>${bandLabels[i]}</td><td>$${r.WITH.toLocaleString()}</td><td>$${r.WITHOUT.toLocaleString()}</td><td>$${r.TENTA.toLocaleString()}</td>`;
    tbody.appendChild(tr);
  });

  /* ── Update quote ── */
  function updateResult(){
    const area=document.getElementById("resultArea");
    const btn =document.getElementById("acceptBtn");

    // active band highlight
    const allRows=tbody.querySelectorAll("tr");
    let activeBand=-1;
    if(rev>0&&rev<REFERRAL){
      const idx=[...rates].reverse().findIndex(r=>rev>=r.min);
      activeBand=idx>=0?rates.length-1-idx:-1;
    }
    allRows.forEach((tr,i)=>tr.classList.toggle("active-row",i===activeBand));

    if(rev===0){ 
      area.innerHTML=`<div class="empty-state">Enter a revenue figure above to generate your quote</div>`; 
      btn.classList.add("hidden"); 
      return; 
    }
    if(rev>=REFERRAL){
      area.innerHTML=`<div class="referral-alert"><div class="referral-icon">⚠️</div><div><div class="referral-title">Referral Required</div><div class="referral-text">Revenue exceeds $20,000,000. Please contact our sales team for a custom quote.</div></div></div>`;
      btn.classList.add("hidden"); 
      return;
    }

    const base=getPremium(rev,opt), tax=base*TAX, ship=rev>SHIP_CAP?0:SHIP_FEE, total=base*(1+TAX)+ship;
    const shipHTML=ship===0?`<span class="shipping-badge">✓ Waived</span>`:cad(ship);

    area.innerHTML=`
      <div class="result-box">
        <div class="result-row"><span class="result-row-label">Base Premium</span><span class="result-row-value">${cad(base)}</span></div>
        <div class="result-row"><span class="result-row-label">HST / Tax (13%)</span><span class="result-row-value">${cad(tax)}</span></div>
        <div class="result-row"><span class="result-row-label">Shipping &amp; Handling</span><span class="result-row-value">${shipHTML}</span></div>
        <div class="result-row result-total result-animate"><span class="result-row-label">Total Premium</span><span class="result-row-value">${cad(total)}</span></div>
      </div>`;
    btn.classList.remove("hidden");
  }

  /* ── Generate certificate ── */
  function generateCertificate(){
    const meta=OPTION_META[opt];
    const base=getPremium(rev,opt), tax=base*TAX, ship=rev>SHIP_CAP?0:SHIP_FEE, total=base*(1+TAX)+ship;
    const polNo=policyNo();

    const corners=["tl","tr","bl","br"].map(cls=>`<svg class="cert-corner ${cls}" viewBox="0 0 56 56"><use href="#corner-sym"/></svg>`).join("");
    const watermark=meta.watermark?`<div class="cert-watermark">PROVISIONAL</div>`:"";

    document.getElementById("certificateEl").className=`certificate ${meta.certClass}`;
    document.getElementById("certificateEl").innerHTML=`
      ${corners}${watermark}

      <div class="cert-header">
        <div class="cert-issuer">Certified Insurance Underwriters of Canada</div>
        <div class="cert-title-main">Certificate of Insurance</div>
        <div class="cert-title-sub">Commercial Policy Document</div>
      </div>

      <div class="cert-ornament"><div class="cert-diamond"></div><div class="cert-diamond"></div><div class="cert-diamond"></div></div>

      <div class="cert-intro">
        This is to certify that the commercial insurance policy described herein has been issued in accordance
        with the applicable rate schedule, and that coverage is bound subject to all conditions stated below.
      </div>

      <div class="cert-type-badge">${meta.policyType}</div>

      <div class="cert-grid">
        <div class="cert-field">
          <div class="cert-field-label">Policy Number</div>
          <div class="cert-field-value" style="font-family:'JetBrains Mono',monospace;font-size:0.88rem">${polNo}</div>
        </div>
        <div class="cert-field">
          <div class="cert-field-label">Coverage Type</div>
          <div class="cert-field-value">${meta.label}</div>
        </div>
        <div class="cert-field">
          <div class="cert-field-label">Declared Annual Revenue</div>
          <div class="cert-field-value" style="font-family:'JetBrains Mono',monospace;font-size:0.88rem">${cad(rev)}</div>
        </div>
        <div class="cert-field">
          <div class="cert-field-label">Revenue Band</div>
          <div class="cert-field-value">${getBand(rev)}</div>
        </div>
        <div class="cert-field">
          <div class="cert-field-label">Effective Date</div>
          <div class="cert-field-value">${todayStr()}</div>
        </div>
        <div class="cert-field">
          <div class="cert-field-label">Expiry Date</div>
          <div class="cert-field-value">${expiryStr()}</div>
        </div>
        <div class="cert-field">
          <div class="cert-field-label">Base Premium</div>
          <div class="cert-field-value" style="font-family:'JetBrains Mono',monospace;font-size:0.88rem">${cad(base)}</div>
        </div>
        <div class="cert-field">
          <div class="cert-field-label">HST (13%)</div>
          <div class="cert-field-value" style="font-family:'JetBrains Mono',monospace;font-size:0.88rem">${cad(tax)}</div>
        </div>
      </div>

      <div class="cert-premium-row">
        <div>
          <div class="cert-premium-label">Total Annual Premium (incl. all taxes &amp; fees)</div>
          <div class="cert-premium-desc">${meta.desc}</div>
        </div>
        <div class="cert-premium-value">${cad(total)}</div>
      </div>

      <div class="cert-seal-row">
        <div class="cert-signatures">
          <div class="cert-sig">
            <div class="cert-sig-line"></div>
            <div class="cert-sig-name">Authorized Underwriter</div>
            <div class="cert-sig-title">Licensed Insurance Professional</div>
          </div>
          <div class="cert-sig">
            <div class="cert-sig-line"></div>
            <div class="cert-sig-name">Broker of Record</div>
            <div class="cert-sig-title">Registered Insurance Broker</div>
          </div>
        </div>
        <div class="cert-seal">
          <div class="cert-seal-star">★</div>
          <div class="cert-seal-text">${meta.sealLines[0]}<br>${meta.sealLines[1]}</div>
        </div>
      </div>

      <div class="cert-policy-bar">
        <span class="cert-policy-num">POLICY NO. ${polNo}</span>
        <span class="cert-policy-date">Issued ${todayStr()}</span>
      </div>
    `;
  }

  /* ── Events ── */
  document.getElementById("revenueInput").addEventListener("input",e=>{
    const raw=e.target.value.replace(/[^0-9]/g,"");
    rev=raw?Number(raw):0;
    e.target.value=raw?num(Number(raw)):"";
    updateResult();
  });

  document.querySelectorAll(".option-pill").forEach(p=>{
    p.addEventListener("click",()=>{
      document.querySelectorAll(".option-pill").forEach(x=>x.classList.remove("active"));
      p.classList.add("active"); 
      opt=p.dataset.option; 
      updateResult();
    });
  });

  document.getElementById("acceptBtn").addEventListener("click",()=>{
    generateCertificate();
    document.getElementById("modal").classList.add("visible");
  });

  document.getElementById("btnClose").addEventListener("click",()=>document.getElementById("modal").classList.remove("visible"));
  document.getElementById("modal").addEventListener("click",e=>{ if(e.target===document.getElementById("modal")) document.getElementById("modal").classList.remove("visible"); });

  document.getElementById("tableToggle").addEventListener("click",()=>{
    document.getElementById("rateTableWrap").classList.toggle("open");
    document.getElementById("tableToggle").classList.toggle("open");
  });
</script>
</body>
</html>
